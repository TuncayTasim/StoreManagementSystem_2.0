{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=StoreManagementSystem;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "REPLACE_WITH_A_SECURE_KEY_AT_LEAST_32_CHARACTERS_LONG"
  },
  "EmailSettings": {
    "FromEmail": "YOUR_GMAIL_ADDRESS@gmail.com",
    "Password": "YOUR_GMAIL_APP_PASSWORD"
  }
}
